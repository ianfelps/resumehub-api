# Copy to .env and fill in real values. .env is git-ignored — never commit secrets.
# Nested config keys use "__" (double underscore), e.g. ConnectionStrings:Default => ConnectionStrings__Default.
# Values here override appsettings.json at runtime.

# --- PostgreSQL (Supabase) ---
# Prefira "SSL Mode=VerifyFull" para validar o certificado do servidor (evita MITM).
# "Trust Server Certificate=true" DESLIGA a validação do certificado — use só em dev local.
ConnectionStrings__Default=Host=db.<project>.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=<password>;SSL Mode=VerifyFull

# --- JWT (use a long random secret, >= 32 chars) ---
Jwt__Issuer=ResumeHub
Jwt__Audience=ResumeHubClients
Jwt__Key=replace-with-a-long-random-secret-at-least-32-chars
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# --- CORS (origin of the Next.js frontend; defaults to http://localhost:3000) ---
Cors__WebOrigin=http://localhost:3000
